DJANGO_SECRET_KEY=replace-with-a-generated-django-secret-key
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=.vercel.app,localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=https://*.vercel.app

# Use a managed PostgreSQL database for Vercel deployments.
DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/DBNAME

# xAI Grok. Do not commit real keys.
XAI_API_KEY=xai-your-key-here
XAI_MODEL=grok-4.3
